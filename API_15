    try:
        q = f"""
            SELECT time, x
            FROM {TABLE_LEMI}
            WHERE time >= %s AND time < %s
              AND x IS NOT NULL
            ORDER BY time ASC
        """
        df = pd.read_sql(q, conn, params=[start, end])
    finally:
        conn.close()

    if df.empty:
        return pd.DataFrame(columns=["H"])

    df["time"] = pd.to_datetime(df["time"], errors="coerce")
    df = df.dropna(subset=["time"]).set_index("time").sort_index()
    df["x"] = pd.to_numeric(df["x"], errors="coerce")

    # =========================================================
    # Hampel SOLO para K
    # =========================================================
    if usar_hampel:
        qc = aplicar_hampel_para_k(
            df["x"],
            window_size=hampel_window,
            n_sigmas=hampel_n_sigmas,
            replace_mode=hampel_replace_mode,
            solo_aislados=True
        )

        df["x_k"] = qc["serie_filtrada"]
        df["qc_spike_flag"] = qc["flags"]

        print(
            f">>> [K Hampel] {start} -> {end} | spikes detectados en x: {qc['n_outliers']}",
            flush=True
        )
    else:
        df["x_k"] = df["x"]
        df["qc_spike_flag"] = False

    # Convertir a H SOLO para K
    df["H"] = H0 + df["x_k"]

    base = df[["H"]].copy()
    counts = base.resample("1min").count()
    means  = base.resample("1min").mean()

    means.loc[counts["H"] < min_samples_per_minute, "H"] = np.nan

    return means


def leer_serie_k_minuto_mixta(
    start,
    end,
    min_samples_per_minute=20,
    usar_hampel=True,
    hampel_window=9,
    hampel_n_sigmas=6,
    hampel_replace_mode="median"
):
    """
    Lee una serie H a minuto usando:
      - fuq_xy_1min antes de FECHA_CORTE_K
      - LEMI desde FECHA_CORTE_K en adelante

    Si el rango cruza la fecha de corte, concatena ambas.

    El filtro de Hampel se aplica SOLO al tramo LEMI usado para K.
    """
    start = pd.Timestamp(start)
    end   = pd.Timestamp(end)

    partes = []

    if start < FECHA_CORTE_K:
        hist_end = min(end, FECHA_CORTE_K)
        df_hist = leer_serie_k_minuto_historica(start, hist_end)
        if not df_hist.empty:
            partes.append(df_hist)

    if end > FECHA_CORTE_K:
        lemi_start = max(start, FECHA_CORTE_K)
        df_lemi = leer_serie_k_minuto_lemi(
            lemi_start,
            end,
            min_samples_per_minute=min_samples_per_minute,
            usar_hampel=usar_hampel,
            hampel_window=hampel_window,
            hampel_n_sigmas=hampel_n_sigmas,
            hampel_replace_mode=hampel_replace_mode
        )
        if not df_lemi.empty:
            partes.append(df_lemi)

    if not partes:
        return pd.DataFrame(columns=["H"])

    df = pd.concat(partes, axis=0)
    df = df[~df.index.duplicated(keep="last")]
    df = df.sort_index()

    df = df.resample("1min").mean()

    return df


def construir_sr_con_fallback_mixto(window_end, meses_preferidos=1, meses_max=6, min_quiet_days=3):
    """
    Igual que tu construir_sr_con_fallback(), pero usando serie mixta.
    """
    window_end = pd.Timestamp(window_end).floor("h")
    ultimo_error = None

    for meses in range(meses_preferidos, meses_max + 1):
        try:
            sr_start = (window_end - pd.DateOffset(months=meses)).floor("D")
            sr_end   = window_end.floor("D") + pd.Timedelta(days=1)

            print(f">>> [MIXTO] Intentando SR con {meses} mes(es): {sr_start} -> {sr_end}", flush=True)

            df_hist = leer_serie_k_minuto_mixta(sr_start, sr_end)
            print(f">>> [MIXTO] df_hist.shape={df_hist.shape}", flush=True)

            if df_hist.empty:
                ultimo_error = f"Sin datos históricos para {meses} mes(es)"
                continue

            quiet_days = seleccionar_quiet_days_simple(df_hist)
            print(f">>> [MIXTO] quiet_days encontrados={len(quiet_days)}", flush=True)

            if len(quiet_days) < min_quiet_days:
                ultimo_error = f"Muy pocos quiet days para {meses} mes(es): {len(quiet_days)}"
                continue

            sr_info = construir_sr_canonica(df_hist, quiet_days)

            return {
                "sr": sr_info["sr"],
                "quiet_days": quiet_days,
                "sr_start": sr_start,
                "sr_end": sr_end,
                "meses_usados": meses,
                "mejor_modelo": sr_info["mejor_modelo"],
                "resumen_modelos": sr_info["resumen_modelos"]
            }

        except Exception as e:
            ultimo_error = str(e)
            print(f"⚠️ [MIXTO] Falló SR con {meses} mes(es): {e}", flush=True)

    raise RuntimeError(
        f"No fue posible construir SR mixta con fallback hasta {meses_max} meses. "
        f"Último error: {ultimo_error}"
    )

def guardar_k_rt_batch(payloads):
    """
    Guarda múltiples resultados en K_RT con un solo commit.
    Devuelve cuántos registros fueron guardados.
    """
    if not payloads:
        return 0

    conn = get_connection()
    cur = conn.cursor()

    try:
        rows = []
        for p in payloads:
            rows.append((
                p["time_calc"],
                p["window_start"],
                p["window_end"],
                p["range_h"],
                p["range_d"],
                p["range_used"],
                p["component_used"],
                p["k_est"],
                p["qc_flag"],
                p["n_valid_h"],
                p["n_valid_d"],
                p["sr_start"],
                p["sr_end"],
                p["quiet_days_used"],
                p.get("sr_run_id"),
                p.get("sr_months_used")
            ))

        sql = f"""
            INSERT INTO {K_TABLE_RT} (
                time_calc,
                window_start,
                window_end,
                range_h,
                range_d,
                range_used,
                component_used,
                k_est,
                qc_flag,
                n_valid_h,
                n_valid_d,
                sr_start,
                sr_end,
                quiet_days_used,
                sr_run_id,
                sr_months_used
            )
            VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s, %s)
            ON DUPLICATE KEY UPDATE
                window_start = VALUES(window_start),
                window_end = VALUES(window_end),
                range_h = VALUES(range_h),
                range_d = VALUES(range_d),
                range_used = VALUES(range_used),
                component_used = VALUES(component_used),
                k_est = VALUES(k_est),
                qc_flag = VALUES(qc_flag),
                n_valid_h = VALUES(n_valid_h),
                n_valid_d = VALUES(n_valid_d),
                sr_start = VALUES(sr_start),
                sr_end = VALUES(sr_end),
                quiet_days_used = VALUES(quiet_days_used),
                sr_run_id = VALUES(sr_run_id),
                sr_months_used = VALUES(sr_months_used)
        """

        cur.executemany(sql, rows)
        conn.commit()

        try:
            _ = cur.rowcount
        except:
            pass

        return len(rows)

    except Exception:
        conn.rollback()
        raise

    finally:
        cur.close()
        conn.close()

def flush_krt_payloads(payloads, *, procesados=None, total_cierres=None,
                       insertados_memoria=None, guardados_total=None,
                       omitidos_existentes=None, warming_up=None,
                       errores=None, motivo="batch"):
    """
    Persiste inmediatamente lo acumulado en memoria y limpia el buffer.
    """
    if not payloads:
        return 0, []

    guardados = guardar_k_rt_batch(payloads)
    print(
        f"💾 BACKFILL {motivo} guardado: {guardados} | "
        f"procesados={procesados}/{total_cierres} | "
        f"insertados_memoria={insertados_memoria} | "
        f"guardados_total={(guardados_total or 0) + guardados} | "
        f"pendientes=0 | "
        f"omitidos_existentes={omitidos_existentes} | "
        f"warming_up={warming_up} | "
        f"errores={0 if errores is None else len(errores)}",
        flush=True
    )
    return guardados, []

