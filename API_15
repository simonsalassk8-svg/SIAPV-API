# ============================================================
@app.post("/dst/recalcular")
def dst_recalcular():
    """
    Corre FFT sobre TODOS los E_avg de la tabla DST y llena
    Sq, SC, Dist, DLAT para todos los registros históricos.
    Puede tardar 1-2 minutos.
    """
    from scipy.fft import fft as sfft, fftfreq as sfftfreq, ifft as sifft
    conn = None
    try:
        conn = get_connection()
        cur  = conn.cursor()

        # Leer TODOS los datos
        cur.execute("""
            SELECT time, E_avg FROM DST
            WHERE E_avg IS NOT NULL
            ORDER BY time ASC
        """)
        rows = cur.fetchall()
        print(f"  [RECALC] {len(rows)} puntos totales")

        if len(rows) < 1440:
            return {"ok": False, "msg": f"Solo {len(rows)} puntos, mínimo 1440"}

        tiempos = [r[0] for r in rows]
        E_vals  = [float(r[1]) for r in rows]

        # Serie minutal uniforme
        E_series = pd.Series(E_vals, index=pd.DatetimeIndex(tiempos), dtype=float)
        E_series = E_series.resample("min").mean()
        E_series = E_series.interpolate(method="linear", limit=120)
        E_clean  = E_series.dropna()

        y    = E_clean.values.astype(float)
        N    = len(y)
        freq = sfftfreq(N, d=1.0)

        omega_d = 1 / (24 * 60)
        omega_m = 1 / (30 * 24 * 60)
        omega_a = 1 / (365 * 24 * 60)

        Y  = sfft(y)
        B  = build_B_filter(freq, omega_d, omega_m, omega_a)
        Sq = sifft(Y * B).real

        f_cut = 1.0 / (3 * 365 * 24 * 60)
        H_sc  = (np.abs(freq) <= f_cut).astype(float)
        SC    = sifft(Y * H_sc).real

        Dist = y - Sq - SC
        DLAT = Dist / np.cos(LAMBDA_B_RAD)

        # Actualizar en batch
        batch = []
        for i, t in enumerate(E_clean.index):
            batch.append((
                float(Sq[i]), float(SC[i]),
                float(Dist[i]), float(DLAT[i]),
                t.strftime("%Y-%m-%d %H:%M:00")
            ))

        cur.executemany("""
            UPDATE DST SET Sq=%s, SC=%s, Dist=%s, DLAT=%s
            WHERE time=%s
        """, batch)
        conn.commit()

        print(f"  [RECALC] ✅ {len(batch)} registros actualizados")
        return {"ok": True, "actualizados": len(batch)}

    except Exception as e:
        print(f"  [RECALC] ❌ {e}")
        return JSONResponse({"error": str(e)}, status_code=500)
    finally:
        if conn:
            conn.close()

