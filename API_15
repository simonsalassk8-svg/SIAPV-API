# AURORA OBSERVATIONS — Aurorasaurus
# ============================================================
AURORA_CACHE: dict = {
    "updated_at"   : None,
    "items"        : [],
    "source_status": "empty",
}
AURORA_CACHE_TTL_MIN = 30
AURORA_MAX_ITEMS     = 9


def _aurora_cache_fresh() -> bool:
    if AURORA_CACHE["updated_at"] is None:
        return False
    age = (_utc_now() - AURORA_CACHE["updated_at"]).total_seconds()
    return age < AURORA_CACHE_TTL_MIN * 60


def _build_aurora_payload(items, source_status, warning=None):
    payload = {
        "updated_at"      : _utc_now().isoformat(),
        "cache_updated_at": AURORA_CACHE["updated_at"].isoformat() if AURORA_CACHE["updated_at"] else None,
        "source_status"   : source_status,
        "total"           : len(items),
        "items"           : items,
    }
    if warning:
        payload["warning"] = warning
    return payload


@app.get("/spaceweather/aurora_obs")
def get_aurora_observations(force_refresh: bool = False):
    """
    Avistamientos recientes de aurora desde Aurorasaurus.
    TTL de caché = 30 min. Falla graciosamente si la API no responde.
    """
    if not force_refresh and _aurora_cache_fresh() and AURORA_CACHE["items"]:
        return _build_aurora_payload(AURORA_CACHE["items"], "fresh")

    try:
        url = "https://api.aurorasaurus.org/v1/tweets"
        params = {
            "north"   : 90,
            "south"   : -90,
            "east"    : 180,
            "west"    : -180,
            "verified": "true",
        }
        resp = requests.get(url, params=params, timeout=12)
        resp.raise_for_status()
        data = resp.json()

        features = []
        if isinstance(data, dict):
            features = data.get("features", [])
        elif isinstance(data, list):
            features = data

        items = []
        for feat in features[:AURORA_MAX_ITEMS]:
            props  = feat.get("properties", {}) if isinstance(feat, dict) else {}
            geom   = feat.get("geometry",   {}) if isinstance(feat, dict) else {}
            coords = geom.get("coordinates", []) if isinstance(geom, dict) else []

            text      = props.get("tweet_text") or props.get("body") or props.get("text") or ""
            location  = (
                props.get("location_name")
                or props.get("place")
                or props.get("location")
                or "Ubicación desconocida"
            )
            created   = props.get("created_at") or props.get("time") or props.get("timestamp")
            image_url = props.get("photo_url") or props.get("media_url") or None
            lat = float(coords[1]) if len(coords) > 1 else None
            lon = float(coords[0]) if len(coords) > 0 else None

            items.append({
                "text"      : str(text)[:280],
                "location"  : str(location),
                "lat"       : lat,
                "lon"       : lon,
                "created_at": str(created) if created else None,
                "image_url" : str(image_url) if image_url else None,
                "source"    : "Aurorasaurus",
            })

        AURORA_CACHE["updated_at"]    = _utc_now()
        AURORA_CACHE["items"]         = items
        AURORA_CACHE["source_status"] = "fresh"

        return _build_aurora_payload(items, "fresh")

    except requests.HTTPError as e:
        status_code = getattr(e.response, "status_code", None)
        if AURORA_CACHE["items"]:
            return _build_aurora_payload(
                AURORA_CACHE["items"], "stale",
                warning=f"HTTP {status_code} de Aurorasaurus — devolviendo caché previa."
            )
        return JSONResponse(
            status_code=502,
            content=_build_aurora_payload(
                [], "error",
                warning=f"No se pudo contactar Aurorasaurus: HTTP {status_code}"
            )
        )

    except Exception as e:
        if AURORA_CACHE["items"]:
            return _build_aurora_payload(
                AURORA_CACHE["items"], "stale",
                warning=f"Error al actualizar avistamientos: {e}"
            )
        return JSONResponse(
            status_code=500,
            content=_build_aurora_payload([], "error", warning=f"Error interno: {e}"))


# ============================================================
# DST KYOTO WDC — índice de tormenta geomagnética (72 h)
# ============================================================
DST_KYO_CACHE: dict = {"updated_at": None, "data": [], "source": "kyoto_wdc"}
DST_KYO_TTL_MIN = 60   # refresca cada hora (Kyoto actualiza ~cada hora)


def _dst_kyo_fresh() -> bool:
    if not DST_KYO_CACHE["updated_at"]:
        return False
    age = (datetime.now(timezone.utc)
           - datetime.fromisoformat(DST_KYO_CACHE["updated_at"])
           ).total_seconds() / 60
    return age < DST_KYO_TTL_MIN


def _parse_kyoto_dst_html(html: str, year: int, month: int) -> list:
    """Parse the Kyoto WDC real-time Dst HTML page.

    The page contains a text block (inside the HTML) with rows of:
      DD  h1  h2  h3 ... h24
    where DD is the day of month and h1..h24 are hourly Dst values in nT.
    Sentinel/missing values are large numbers (≥9000).
    """
    import re

    # Strip HTML tags to get plain text
    plain = re.sub(r"<[^>]+>", " ", html)

    records = []
    for line in plain.splitlines():
        line = line.strip()
        # Match lines that start with a day number (1-31) followed by ≥5 integers
        m = re.match(r"^\s*(\d{1,2})\s+((?:-?\d+\s+){4,})", line)
        if not m:
            continue
        try:
            dd = int(m.group(1))
            if not (1 <= dd <= 31):
                continue
            # Extract all signed integers from the line (skip the day itself)
            vals = [int(v) for v in re.findall(r"-?\d+", line)]
            if not vals or vals[0] != dd:
                continue
            hourly = vals[1:]   # remaining values = hourly Dst
            for hour, val in enumerate(hourly[:24]):
                if abs(val) >= 9000:   # sentinel / missing
                    continue
                try:
                    dt = datetime(year, month, dd, hour, tzinfo=timezone.utc)
                except ValueError:
                    continue
                records.append({
                    "time": dt.isoformat().replace("+00:00", "Z"),
                    "dst":  val,
                })
        except (ValueError, IndexError):
            continue

    return sorted(records, key=lambda r: r["time"])


@app.get("/spaceweather/dst_kyoto")
def get_dst_kyoto(force: bool = False):
    """Return last 72 h of hourly Dst from Kyoto WDC real-time HTML page."""
    if not force and _dst_kyo_fresh():
        return DST_KYO_CACHE

    now = datetime.now(timezone.utc)
    records: list = []

    # Try current month then previous month to ensure full 72-h coverage
    for delta_months in [0, -1]:
        if delta_months == 0:
            target = now
        else:
            target = now.replace(day=1) - timedelta(days=1)

        year  = target.year
        month = target.month
        url   = f"https://wdc.kugi.kyoto-u.ac.jp/dst_realtime/{year}{month:02d}/"
        try:
            resp = requests.get(url, timeout=12, headers={"User-Agent": "Mozilla/5.0"})
            resp.raise_for_status()
            parsed = _parse_kyoto_dst_html(resp.text, year, month)
            records.extend(parsed)
        except Exception:
            pass   # try next month

    if records:
        cutoff = (now - timedelta(hours=72)).isoformat().replace("+00:00", "Z")
        records = sorted(
            [r for r in records if r["time"] >= cutoff],
            key=lambda r: r["time"]
        )
        DST_KYO_CACHE.update({
            "updated_at": now.isoformat().replace("+00:00", "Z"),
            "data":       records,
            "source":     "kyoto_wdc",
        })
        return DST_KYO_CACHE

    # Fallback: return stale cache if available
    if DST_KYO_CACHE["data"]:
        return {**DST_KYO_CACHE, "warning": "Caché anterior (Kyoto WDC no respondió)"}

    return JSONResponse(
        status_code=502,
        content={"data": [], "warning": "No se pudo obtener Dst de Kyoto WDC", "updated_at": None},
    )