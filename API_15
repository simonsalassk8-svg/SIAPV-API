from fastapi.responses import StreamingResponse, JSONResponse
import io
import math
from datetime import datetime, timedelta
@app.get("/download")
def download_data(var: str, format: str, dateFrom: str, dateTo: str):
    # =====================================================================
    # 1. VISTA PREVIA JSON (Gráfica rápida con saltos de tiempo)
    # =====================================================================
    if format == 'json':
        conn = get_connection()
        try:
            cur = conn.cursor()
            data = []
            
            start_dt = datetime.strptime(f"{dateFrom} 00:00:00", "%Y-%m-%d %H:%M:%S")
            end_dt = datetime.strptime(f"{dateTo} 23:59:59", "%Y-%m-%d %H:%M:%S")
            
            total_seconds = (end_dt - start_dt).total_seconds()
            puntos_deseados = 800
            step_seconds = max(1, int(total_seconds / puntos_deseados))
            
            # Selección de tabla y columnas según variable
            if var == 'k':
                tabla, cols, time_col = K_TABLE_RT, "time_calc, k_est", "time_calc"
            elif var in ['sq', 'e', 'dlat']:
                col = 'Sq' if var=='sq' else 'E_avg' if var=='e' else 'DLAT'
                tabla, cols, time_col = "DST", f"time, {col}", "time"
            elif var == 'f':
                tabla, cols, time_col = TABLE_GSM, "time, f", "time"
            else:
                tabla, cols, time_col = TABLE_LEMI, "time, x, y, z", "time"

            current_time = start_dt
            while current_time <= end_dt and len(data) < puntos_deseados:
                cur.execute(f"SELECT {cols} FROM {tabla} WHERE {time_col} >= %s AND {time_col} <= %s ORDER BY {time_col} ASC LIMIT 1", 
                            (current_time.strftime("%Y-%m-%d %H:%M:%S"), end_dt.strftime("%Y-%m-%d %H:%M:%S")))
                row = cur.fetchone()
                
                if not row:
                    current_time += timedelta(seconds=step_seconds)
                    continue
                    
                t = row[0]
                if var in ['k', 'sq', 'e', 'dlat', 'f']:
                    val = round(row[1], 4) if row[1] is not None else None
                else:
                    dx, dy, dz = row[1], row[2], row[3]
                    if dx is not None:
                        H = H0 + float(dx); Z = Z0 + float(dz)
                        D_min = D0_min + float(dy); D_rad = math.radians(D_min / 60.0)
                        val = None
                        if var == 'h': val = H
                        elif var == 'z': val = Z
                        elif var == 'd': val = D_min / 60.0
                        elif var == 'x': val = H * math.cos(D_rad)
                        elif var == 'y': val = H * math.sin(D_rad)
                        elif var == 'i': val = math.degrees(math.atan2(Z, H)) if H != 0 else 0
                        if val is not None: val = round(val, 4)
                    else: val = None

                if val is not None:
                    data.append({"time": str(t), "value": val})
                current_time += timedelta(seconds=step_seconds)

            return JSONResponse(content={"variable": var, "puntos_graficados": len(data), "data": data})
        except Exception as e:
            return JSONResponse(content={"error": str(e)}, status_code=500)
        finally:
            cur.close(); conn.close()

    # =====================================================================
    # 2. STREAMING DE ALTA VELOCIDAD (Un solo archivo con ; y 99999)
    # =====================================================================
    def iter_data():
        start_dt = datetime.strptime(dateFrom, "%Y-%m-%d")
        end_dt = datetime.strptime(dateTo, "%Y-%m-%d")

        # Cabecera con Punto y Coma para Excel
        header = io.StringIO()
        if format == 'csv':
            header.write(f"time;{var}\n")
        elif format == 'iaga2002':
            header.write(f" Format                 IAGA-2002                                    |\n")
            header.write(f" Source of Data         FUQ Observatory                              |\n")
            header.write(f"DATE       TIME         DOY     {var.upper()}                    |\n")
        yield header.getvalue()

        current_dt = start_dt
        while current_dt <= end_dt:
            day_start = current_dt.strftime("%Y-%m-%d 00:00:00")
            day_end = current_dt.strftime("%Y-%m-%d 23:59:59")
            
            conn = get_connection()
            try:
                cur = conn.cursor()
                # Consultas optimizadas (sin filtrar IS NOT NULL para detectar huecos)
                if var == 'k':
                    query = f"SELECT time_calc, k_est FROM {K_TABLE_RT} WHERE time_calc >= %s AND time_calc <= %s ORDER BY time_calc ASC"
                elif var in ['sq', 'e', 'dlat']:
                    col = 'Sq' if var=='sq' else 'E_avg' if var=='e' else 'DLAT'
                    query = f"SELECT time, {col} FROM DST WHERE time >= %s AND time <= %s ORDER BY time ASC"
                elif var == 'f':
                    query = f"SELECT time, f FROM {TABLE_GSM} WHERE time >= %s AND time <= %s ORDER BY time ASC"
                else:
                    query = f"SELECT time, x, y, z FROM {TABLE_LEMI} WHERE time >= %s AND time <= %s ORDER BY time ASC"

                cur.execute(query, (day_start, day_end))
                
                while True:
                    rows = cur.fetchmany(20000) # Bloques grandes para velocidad
                    if not rows: break 
                    
                    output = io.StringIO()
                    for row in rows:
                        # Lógica de reemplazo por 99999 si el dato es None
                        if var == 'k':
                            val = row[1] if row[1] is not None else 99999
                            output.write(f"{row[0]};{val}\n" if format == 'csv' else f"{row[0]}   {val}\n")
                        elif var in ['sq', 'e', 'dlat', 'f']:
                            val = round(row[1], 4) if row[1] is not None else 99999
                            output.write(f"{row[0]};{val}\n" if format == 'csv' else f"{row[0]}   {val}\n")
                        else:
                            t, dx, dy, dz = row
                            if dx is None:
                                val = 99999
                            else:
                                H = H0 + float(dx); Z = Z0 + float(dz)
                                D_min = D0_min + float(dy); D_rad = math.radians(D_min / 60.0)
                                res = None
                                if var == 'h': res = H
                                elif var == 'z': res = Z
                                elif var == 'd': res = D_min / 60.0
                                elif var == 'x': res = H * math.cos(D_rad)
                                elif var == 'y': res = H * math.sin(D_rad)
                                elif var == 'i': res = math.degrees(math.atan2(Z, H)) if H != 0 else 0
                                val = round(res, 4) if res is not None else 99999
                            output.write(f"{t};{val}\n" if format == 'csv' else f"{t}   {val}\n")
                    yield output.getvalue()
                cur.close()
            except Exception as e:
                yield f"Error;{str(e)}\n"
            finally:
                if conn: conn.close()
            current_dt += timedelta(days=1)

    # Retorno de la descarga (Un solo archivo plano)
    media = "text/csv" if format == 'csv' else "text/plain"
    ext = "csv" if format == 'csv' else "txt"
    return StreamingResponse(
        iter_data(), 
        media_type=media, 
        headers={"Content-Disposition": f"attachment; filename=fuq_{var}_{dateFrom}_to_{dateTo}.{ext}"}
    )
