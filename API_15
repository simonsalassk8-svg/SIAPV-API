            data.append({
                "time"   : t.strftime("%Y-%m-%d %H:%M:%S"),
                "x"      : X,
                "y"      : Y,
                "z"      : Z,
                "h"      : H,
                "d_min"  : D_min,
                "d_deg"  : D_min / 60.0,
                "i_model": I_model,
                "e_model": E_model,
                "f"      : last_F
            })

        return {
            "station" : "FUQ",
            "baseline": BASELINE,
            "sq_model": {
                "fecha"     : SQ_STATE.fecha_modelo,
                "a0"        : SQ_STATE.a0,
                "a1"        : SQ_STATE.a1,
                "quiet_days": SQ_STATE.quiet_days
