def hampel_filter_fast(series, window_size=9, n_sigmas=6, replace_mode="median"):
    """
    Filtro de Hampel rápido sobre una Serie pandas.
    Devuelve:
      - serie filtrada
      - flags de outliers
      - mediana local
      - umbral local
    """
    x = series.to_numpy(dtype=float)
    n = len(x)

    filtered = x.copy()
    outlier_flags = np.zeros(n, dtype=bool)
    local_medians = np.full(n, np.nan, dtype=float)
    thresholds = np.full(n, np.nan, dtype=float)

    k = 1.4826

    for i in range(window_size, n - window_size):
        window = x[i - window_size : i + window_size + 1]

        med = np.nanmedian(window)
        mad = np.nanmedian(np.abs(window - med))

        local_medians[i] = med

        if np.isnan(mad) or mad == 0:
            continue

        threshold = n_sigmas * k * mad
        thresholds[i] = threshold

        if abs(x[i] - med) > threshold:
            outlier_flags[i] = True

    if replace_mode == "median":
        filtered[outlier_flags] = local_medians[outlier_flags]
    elif replace_mode == "nan":
        filtered[outlier_flags] = np.nan

    return (
        pd.Series(filtered, index=series.index),
        pd.Series(outlier_flags, index=series.index),
        pd.Series(local_medians, index=series.index),
        pd.Series(thresholds, index=series.index),
    )


def dejar_solo_aislados(flags):
    """
    Conserva solo outliers aislados.
    Si un punto marcado tiene vecino también marcado,
    no se considera spike aislado.
    """
    f = flags.to_numpy(dtype=bool)
    out = f.copy()

    for i in range(1, len(f) - 1):
        if f[i] and (f[i - 1] or f[i + 1]):
            out[i] = False

    return pd.Series(out, index=flags.index)


def aplicar_hampel_para_k(
    serie,
    window_size=9,
    n_sigmas=6,
    replace_mode="median",
    solo_aislados=True
):
    """
    Aplica Hampel a una serie 1D para uso en K.
    """
    serie_filtrada_tmp, flags_tmp, mediana_local, umbral_local = hampel_filter_fast(
        serie,
        window_size=window_size,
        n_sigmas=n_sigmas,
        replace_mode=replace_mode
    )

    flags_final = dejar_solo_aislados(flags_tmp) if solo_aislados else flags_tmp

    serie_filtrada = serie.copy()
    if replace_mode == "median":
        serie_filtrada.loc[flags_final] = mediana_local.loc[flags_final]
    elif replace_mode == "nan":
        serie_filtrada.loc[flags_final] = np.nan

    return {
        "serie_filtrada": serie_filtrada,
        "flags": flags_final,
        "n_outliers": int(flags_final.sum()),
        "mediana_local": mediana_local,
        "umbral_local": umbral_local
    }

def leer_serie_k_minuto_historica(start, end):
    """
    Lee la tabla histórica minuto a minuto (fuq_xy_1min).
    Intenta detectar si la columna magnética es:
      - H / h   -> ya viene como H absoluto
      - x       -> se interpreta como delta y se convierte a H = H0 + x
    """
    conn = get_connection()
    try:
        cols = get_table_columns(TABLE_MINUTO_HIST)

        if "h" in cols:
            mag_col = "h"
            modo = "H_ABS"
        elif "H" in cols:
            mag_col = "H"
            modo = "H_ABS"
        elif "x" in cols:
            mag_col = "x"
            modo = "DELTA_X"
        elif "X" in cols:
            mag_col = "X"
            modo = "DELTA_X"
        else:
            raise RuntimeError(
                f"No encontré columna H/h/x/X en {TABLE_MINUTO_HIST}. "
                f"Columnas detectadas: {cols}"
            )

        q = f"""
            SELECT time, {mag_col} AS mag
            FROM {TABLE_MINUTO_HIST}
            WHERE time >= %s AND time < %s
              AND {mag_col} IS NOT NULL
            ORDER BY time ASC
        """
        df = pd.read_sql(q, conn, params=[start, end])

    finally:
        conn.close()

    if df.empty:
        return pd.DataFrame(columns=["H"])

    df["time"] = pd.to_datetime(df["time"], errors="coerce")
    df = df.dropna(subset=["time"]).set_index("time").sort_index()
    df["mag"] = pd.to_numeric(df["mag"], errors="coerce")

    if modo == "H_ABS":
        df["H"] = df["mag"]
    else:
        df["H"] = H0 + df["mag"]

    # Por si acaso, normalizamos a 1 minuto
    out = df[["H"]].resample("1min").mean()
    return out


def leer_serie_k_minuto_lemi(
