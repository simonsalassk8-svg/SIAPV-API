def build_B_filter(freq, omega_d, omega_m, omega_a):
    """Filtro multi-band-pass igual al código histórico."""
    B = np.zeros_like(freq, dtype=bool)
    for k in range(1, MAX_D + 1):
        f0 = k * omega_d; bw = WIDTH_FACTOR * f0
        B |= (np.abs(freq - f0) < bw/2) | (np.abs(freq + f0) < bw/2)
    for k in range(1, MAX_M + 1):
        f0 = k * omega_m; bw = WIDTH_FACTOR * f0
        B |= (np.abs(freq - f0) < bw/2) | (np.abs(freq + f0) < bw/2)
    for k in range(1, MAX_A + 1):
        f0 = k * omega_a; bw = WIDTH_FACTOR * f0
        B |= (np.abs(freq - f0) < bw/2) | (np.abs(freq + f0) < bw/2)
    return B.astype(float)


def calcular_sq_sc_sobre_historial(conn):
    """
    Lee los últimos HIST_MINUTOS de E_avg desde DST,
    calcula Sq (FFT filtro B) y SC (lowpass > 3 años).
    Devuelve dict {minuto_str: {"Sq": v, "SC": v, "Dist": v, "DLAT": v}}
    o None si no hay suficientes datos.
    """
    from scipy.fft import fft as sfft, fftfreq as sfftfreq, ifft as sifft
    try:
        cur = conn.cursor()
        cur.execute("""
            SELECT time, E_avg FROM DST
            WHERE E_avg IS NOT NULL
            ORDER BY time DESC
            LIMIT %s
        """, (HIST_MINUTOS,))
        rows = cur.fetchall()
        cur.close()

        if len(rows) < 1440:
            print(f"  [FFT] Solo {len(rows)} puntos, mínimo 1440.")
            return None

        rows = list(reversed(rows))
        tiempos = [r[0] for r in rows]
        E_vals  = [float(r[1]) for r in rows]

        # Serie pandas minutal uniforme
        E_series = pd.Series(E_vals, index=pd.DatetimeIndex(tiempos), dtype=float)
        E_series = E_series.resample("min").mean()
        E_series = E_series.interpolate(method="linear", limit=120)
        E_clean  = E_series.dropna()

        if len(E_clean) < 1440:
            return None

        y    = E_clean.values.astype(float)
        N    = len(y)
        freq = sfftfreq(N, d=1.0)   # ciclos por minuto

        omega_d = 1 / (24 * 60)
        omega_m = 1 / (30 * 24 * 60)
        omega_a = 1 / (365 * 24 * 60)

        Y  = sfft(y)
        B  = build_B_filter(freq, omega_d, omega_m, omega_a)
        Sq = sifft(Y * B).real

        f_cut = 1.0 / (3 * 365 * 24 * 60)
        H_sc  = (np.abs(freq) <= f_cut).astype(float)
        SC    = sifft(Y * H_sc).real

        Dist = y - Sq - SC
        DLAT = Dist / np.cos(LAMBDA_B_RAD)

        # Construir dict indexado por timestamp string
        resultado = {}
        for i, t in enumerate(E_clean.index):
            key = t.strftime("%Y-%m-%d %H:%M:00")
            resultado[key] = {
                "Sq"  : float(Sq[i]),
                "SC"  : float(SC[i]),
                "Dist": float(Dist[i]),
                "DLAT": float(DLAT[i]),
            }

        print(f"  [FFT] Calculados {len(resultado)} puntos de Sq/SC/Dist/DLAT")
        return resultado

    except Exception as e:
        print(f"  [FFT] Error: {e}")
        return None

def calcular_sq_sc_rt(conn):
    """
    FFT rápido sobre últimos 3 días (4320 puntos).
    Se corre cada minuto para tener Sq/Dist/DLAT en tiempo real.
    Menos preciso que el de 30 días pero suficiente para tiempo real.
    """
    from scipy.fft import fft as sfft, fftfreq as sfftfreq, ifft as sifft
    try:
        cur = conn.cursor()
        cur.execute("""
            SELECT time, E_avg FROM DST
            WHERE E_avg IS NOT NULL
            ORDER BY time DESC
            LIMIT 70000
        """)
        rows = cur.fetchall()
        cur.close()

        if len(rows) < 1440:
            return None

        rows = list(reversed(rows))
        tiempos = [r[0] for r in rows]
        E_vals  = [float(r[1]) for r in rows]

        E_series = pd.Series(E_vals, index=pd.DatetimeIndex(tiempos), dtype=float)
        E_series = E_series.resample("min").mean()
        E_series = E_series.interpolate(method="linear", limit=120)
        E_clean  = E_series.dropna()

        if len(E_clean) < 1440:
            return None

        y    = E_clean.values.astype(float)
        N    = len(y)
        freq = sfftfreq(N, d=1.0)

        omega_d = 1 / (24 * 60)
        omega_m = 1 / (30 * 24 * 60)
        omega_a = 1 / (365 * 24 * 60)

        Y  = sfft(y)
        B  = build_B_filter(freq, omega_d, omega_m, omega_a)
        Sq = sifft(Y * B).real

        f_cut = 1.0 / (3 * 365 * 24 * 60)
        H_sc  = (np.abs(freq) <= f_cut).astype(float)
        SC    = sifft(Y * H_sc).real

        Dist = y - Sq - SC
        DLAT = Dist / np.cos(LAMBDA_B_RAD)

        resultado = {}
        for i, t in enumerate(E_clean.index):
            key = t.strftime("%Y-%m-%d %H:%M:00")
            resultado[key] = {
                "Sq"  : float(Sq[i]),
                "SC"  : float(SC[i]),
                "Dist": float(Dist[i]),
                "DLAT": float(DLAT[i]),
            }
        return resultado

    except Exception as e:
        print(f"  [FFT-RT] Error: {e}")
        return None

