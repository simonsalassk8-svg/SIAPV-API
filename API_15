def guardar_sr_en_bd(sr_pack, run_time=None, source="mixto", notes=None):
    if run_time is None:
        run_time = datetime.now()

    sr = sr_pack["sr"]
    quiet_days = sr_pack["quiet_days"]
    sr_start = sr_pack["sr_start"]
    sr_end = sr_pack["sr_end"]
    meses_usados = sr_pack["meses_usados"]

    conn = get_connection()
    cur = conn.cursor()

    try:
        # 1) Guardar cabecera
        cur.execute("""
            INSERT INTO SR_RUN (
                run_time, sr_start, sr_end,
                quiet_days_used, sr_months_used, source, notes
            )
            VALUES (%s, %s, %s, %s, %s, %s, %s)
        """, (
            run_time,
            sr_start.to_pydatetime() if pd.notna(sr_start) else None,
            sr_end.to_pydatetime() if pd.notna(sr_end) else None,
            int(len(quiet_days)),
            int(meses_usados),
            source,
            notes
        ))

        run_id = cur.lastrowid

        # 2) Guardar 1440 puntos
        rows = []
        sr_reset = sr.reset_index()

        for _, row in sr_reset.iterrows():
            rows.append((
                run_id,
                int(row["minute_of_day"]),
                None if pd.isna(row["SR_H"]) else float(row["SR_H"])
            ))

        cur.executemany("""
            INSERT INTO SR_CURVE (run_id, minute_of_day, sr_h)
            VALUES (%s, %s, %s)
        """, rows)

        conn.commit()
        return run_id

    except Exception:
        conn.rollback()
        raise
    finally:
        cur.close()
        conn.close()

def buscar_sr_run_existente(run_date, source="mixto"):
    conn = get_connection()
    cur = conn.cursor()

    try:
        inicio = pd.Timestamp(run_date).floor("D").to_pydatetime()
        fin = (pd.Timestamp(run_date).floor("D") + pd.Timedelta(days=1)).to_pydatetime()

        cur.execute("""
            SELECT id
            FROM SR_RUN
            WHERE run_time >= %s AND run_time < %s
              AND source = %s
            ORDER BY id DESC
            LIMIT 1
        """, (inicio, fin, source))

        row = cur.fetchone()
        return row[0] if row else None

    finally:
        cur.close()
        conn.close()

def cargar_sr_desde_bd(run_id: int):
    conn = get_connection()
    cur = conn.cursor()

    try:
        cur.execute("""
            SELECT minute_of_day, sr_h
            FROM SR_CURVE
            WHERE run_id = %s
            ORDER BY minute_of_day
        """, (run_id,))
        rows = cur.fetchall()

        if not rows:
            raise RuntimeError(f"No hay curva SR para run_id={run_id}")

        sr = pd.DataFrame(rows, columns=["minute_of_day", "SR_H"])
        sr = sr.set_index("minute_of_day")

        idx = pd.Index(range(1440), name="minute_of_day")
        sr = sr.reindex(idx)
        sr["SR_H"] = pd.to_numeric(sr["SR_H"], errors="coerce")
        sr["SR_H"] = sr["SR_H"].interpolate(limit_direction="both")

        return sr

    finally:
        cur.close()
        conn.close()

