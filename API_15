# ============================================================
# SECCIÓN DE CONSUMO DE APIS EXTERNAS - NOTICIAS CLIMA ESPACIAL
# ============================================================

NEWS_CACHE = {
    "updated_at": None,      # datetime UTC del último fetch exitoso
    "items": [],             # últimas noticias buenas
    "query": None,
    "source_status": "empty" # empty | fresh | stale | rate_limited | error
}

NEWS_CACHE_TTL_MIN = 30   # minutos de caché "fresca"
NEWS_MAX_ITEMS = 2


def _utc_now():
    return datetime.now(timezone.utc)


def _cache_age_seconds():
    if NEWS_CACHE["updated_at"] is None:
        return None
    return (_utc_now() - NEWS_CACHE["updated_at"]).total_seconds()


def _cache_is_fresh():
    age = _cache_age_seconds()
    return age is not None and age < NEWS_CACHE_TTL_MIN * 60


def _build_news_payload(items, query, source_status, warning=None, detail=None):
    payload = {
        "updated_at": _utc_now().isoformat(),
        "cache_updated_at": NEWS_CACHE["updated_at"].isoformat() if NEWS_CACHE["updated_at"] else None,
        "source_status": source_status,
        "query": query,
        "total": len(items),
        "items": items
    }
    if warning:
        payload["warning"] = warning
    if detail is not None:
        payload["detail"] = detail
    return payload


def _fetch_spaceweather_news_from_newsapi():
    if not NEWS_API_KEY:
        raise RuntimeError("Falta configurar la variable de entorno NEWS_API_KEY")

    url = "https://newsapi.org/v2/everything"
    from_dt = (_utc_now() - timedelta(days=5)).isoformat()

    query = (
        '"geomagnetic storm" OR "space weather" OR "solar flare" '
        'OR "coronal mass ejection" OR "solar wind"'
    )

    params = {
        "q": query,
        "language": "en",
        "sortBy": "publishedAt",
        "pageSize": 30,
        "from": from_dt,
        "searchIn": "title,description"
    }

    headers = {
        "X-Api-Key": NEWS_API_KEY
    }

    resp = requests.get(url, params=params, headers=headers, timeout=12)
    resp.raise_for_status()
    data = resp.json()
    articles = data.get("articles", [])

    items = []
    seen_urls = set()

    for a in articles:
        title = (a.get("title") or "").strip()
        description = (a.get("description") or "").strip()
        article_url = (a.get("url") or "").strip()
        published_at = a.get("publishedAt")
        source_name = (a.get("source") or {}).get("name", "Fuente desconocida")

        if not title or not article_url:
            continue

        if article_url in seen_urls:
            continue

        url_low = article_url.lower()
        content_all = f"{title} {description}".lower()

        if any(bad_domain in url_low for bad_domain in BLOCKED_DOMAINS):
            continue

        if any(bad in content_all for bad in BAD_KEYWORDS):
            continue

        if not any(good in content_all for good in GOOD_KEYWORDS):
            continue

        seen_urls.add(article_url)

        tag = "Clima espacial"
        if "geomagnetic storm" in content_all or "kp index" in content_all:
            tag = "Tormenta geomagnética"
        elif "solar flare" in content_all:
            tag = "Erupción solar"
        elif "coronal mass ejection" in content_all or "cme" in content_all:
            tag = "CME"
        elif "aurora" in content_all:
            tag = "Aurora"

        priority = 1
        if any(domain in url_low for domain in PREFERRED_DOMAINS):
            priority = 0

        items.append({
            "priority": priority,
            "tag": tag,
            "title": title,
            "summary": description or "Sin resumen disponible.",
            "date": published_at,
            "url": article_url,
            "source": source_name
        })

    items = sorted(
        items,
        key=lambda x: (x["priority"], x["date"] or "")
    )

    cleaned = []
    for item in items[:NEWS_MAX_ITEMS]:
        item.pop("priority", None)
        cleaned.append(item)

    return {
        "query": query,
        "items": cleaned
    }


@app.get("/spaceweather/news")
def get_spaceweather_news(force_refresh: bool = False):
    """
    Endpoint con caché:
    - devuelve caché fresca si existe
    - consulta NewsAPI solo si la caché expiró o si force_refresh=true
    - si NewsAPI responde 429, devuelve caché vieja si existe
    """
    # 1) si no forzaron refresh y la caché sigue fresca, devolvemos eso
    if not force_refresh and _cache_is_fresh():
        return _build_news_payload(
            items=NEWS_CACHE["items"],
            query=NEWS_CACHE["query"],
            source_status="fresh"
        )

    try:
        fetched = _fetch_spaceweather_news_from_newsapi()

        # actualizar caché solo si el fetch fue exitoso
        NEWS_CACHE["updated_at"] = _utc_now()
        NEWS_CACHE["items"] = fetched["items"]
        NEWS_CACHE["query"] = fetched["query"]
        NEWS_CACHE["source_status"] = "fresh"

        return _build_news_payload(
            items=NEWS_CACHE["items"],
            query=NEWS_CACHE["query"],
            source_status="fresh"
        )

    except requests.HTTPError as e:
        status_code = None
        detail = None

        try:
            status_code = e.response.status_code
        except Exception:
            pass

        try:
            detail = e.response.json()
        except Exception:
            try:
                detail = e.response.text
            except Exception:
                detail = str(e)

        # Caso específico: rate limit
        if status_code == 429:
            if NEWS_CACHE["items"]:
                NEWS_CACHE["source_status"] = "rate_limited"
                return JSONResponse(
                    status_code=200,
                    content=_build_news_payload(
                        items=NEWS_CACHE["items"],
                        query=NEWS_CACHE["query"],
                        source_status="stale",
                        warning="NewsAPI alcanzó el límite temporal de peticiones. Se devuelve la última caché disponible.",
                        detail=detail
                    )
                )

            return JSONResponse(
                status_code=429,
                content={
                    "updated_at": _utc_now().isoformat(),
                    "cache_updated_at": None,
                    "source_status": "rate_limited",
                    "items": [],
                    "error": "NewsAPI alcanzó el límite temporal de peticiones y no hay caché disponible.",
                    "detail": detail
                }
            )

        # Otros errores HTTP: si hay caché, usarla
        if NEWS_CACHE["items"]:
            NEWS_CACHE["source_status"] = "error"
            return JSONResponse(
                status_code=200,
                content=_build_news_payload(
                    items=NEWS_CACHE["items"],
                    query=NEWS_CACHE["query"],
                    source_status="stale",
                    warning=f"Fallo consultando NewsAPI ({status_code}). Se devuelve la última caché disponible.",
                    detail=detail
                )
            )

        return JSONResponse(
            status_code=502,
            content={
                "updated_at": _utc_now().isoformat(),
                "cache_updated_at": None,
                "source_status": "error",
                "items": [],
                "error": f"Error HTTP consultando NewsAPI: {str(e)}",
                "detail": detail
            }
        )

    except Exception as e:
        if NEWS_CACHE["items"]:
            NEWS_CACHE["source_status"] = "error"
            return JSONResponse(
                status_code=200,
                content=_build_news_payload(
                    items=NEWS_CACHE["items"],
                    query=NEWS_CACHE["query"],
                    source_status="stale",
                    warning="Error interno consultando NewsAPI. Se devuelve la última caché disponible.",
                    detail=str(e)
                )
            )

        return JSONResponse(
            status_code=500,
            content={
                "updated_at": _utc_now().isoformat(),
                "cache_updated_at": None,
                "source_status": "error",
                "items": [],
                "error": f"Error interno: {str(e)}"
            }
        )


