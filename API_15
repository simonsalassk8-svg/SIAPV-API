async def calcular_k_cada_hora():
    """
    Cada hora calcula K con ventana deslizante de 3 horas
    y lo guarda en K_RT si hay cobertura suficiente.
    """
    while True:
        ahora = datetime.now()
        segundos_restantes = (60 - ahora.minute) * 60 - ahora.second + 2
        if segundos_restantes <= 0:
            segundos_restantes += 3600

        await asyncio.sleep(segundos_restantes)

        try:
            hora_cierre = pd.Timestamp.now().floor("h")
            print(f"🔄 Calculando K horario para {hora_cierre}", flush=True)

            payload = calcular_k_para_hora_mixto(hora_cierre, meses_sr=1)

            if payload.get("status") == "warming_up":
                print(f"⚠️ K no guardado: {payload['message']}", flush=True)
                continue

            guardar_k_rt(payload)

            print(
                f"✅ K_RT guardado: K={payload['k_est']} "
                f"range_h={payload['range_h']:.3f} "
                f"n_valid_h={payload['n_valid_h']}",
                flush=True
            )

        except Exception as e:
            print(f"⚠️ K no guardado por cobertura insuficiente o error: {e}", flush=True)


@app.post("/krt/backfill_historico")
def krt_backfill_historico(
    fecha_inicio: str = "2026-01-01 00:00:00",
    fecha_fin: Optional[str] = None,
    recalcular_existentes: bool = False,
    batch_size: int = 10
):
    """
    Backfill histórico de K_RT usando fuente mixta:
      - antes de 2026-01-01 -> fuq_xy_1min
      - desde 2026-01-01    -> LEMI

    Calcula K para cada cierre TRIHORARIO entre fecha_inicio y fecha_fin:
      00, 03, 06, 09, 12, 15, 18, 21

    Si recalcular_existentes=True:
      - fuerza una SR nueva por día
      - reutiliza esa SR nueva para todos los cierres del mismo día

    Si recalcular_existentes=False:
      - reusa SR existente del día si ya está guardada
    """
    try:
        inicio = pd.Timestamp(fecha_inicio).floor("h")

        if fecha_fin is None:
            fin = pd.Timestamp.now().floor("h")
        else:
            fin = pd.Timestamp(fecha_fin).floor("h")

        if fin < inicio:
            return {"ok": False, "msg": "fecha_fin no puede ser menor que fecha_inicio"}

        # =========================================================
        # SOLO CIERRES TRIHORARIOS
        # =========================================================
        cierres = pd.date_range(start=inicio, end=fin, freq="3h")

        total_cierres = len(cierres)
        procesados = 0
        insertados = 0

        existentes = set()
        if not recalcular_existentes:
            conn = get_connection()
            try:
                q = f"""
                    SELECT time_calc
                    FROM {K_TABLE_RT}
                    WHERE time_calc >= %s AND time_calc <= %s
                """
                df_exist = pd.read_sql(q, conn, params=[inicio, fin])
                if not df_exist.empty:
                    existentes = set(pd.to_datetime(df_exist["time_calc"]).dt.floor("h").tolist())
            finally:
                conn.close()

        payloads_ok = []
        omitidos_existentes = 0
        warming_up = 0
        errores = []
        guardados_total = 0

        if batch_size is None or int(batch_size) <= 0:
            batch_size = 1
        else:
            batch_size = int(batch_size)

        # cache SR por día
        sr_cache_por_dia = {}

        for cierre in cierres:
            procesados += 1
            pct = 100 * procesados / total_cierres

            print(
                f"⏳ BACKFILL [{procesados}/{total_cierres} | {pct:0.1f}%] procesando cierre {cierre}",
                flush=True
            )

            try:
                # -------------------------------------------------
                # Si NO recalcula existentes y ya existe K_RT, omitir
                # -------------------------------------------------
                if (not recalcular_existentes) and (cierre in existentes):
                    omitidos_existentes += 1
                    print(f"↪️ Ya existía en K_RT: {cierre}", flush=True)
                    continue

                dia_key = cierre.floor("D")

                # =================================================
                # CONSTRUIR / REUSAR SR DEL DÍA
                # =================================================
                if dia_key not in sr_cache_por_dia:
                    print(f"🧠 Preparando SR para día base {dia_key}", flush=True)

                    # -------------------------------------------------
                    # Si se forzó recálculo, construir NUEVA SR del día
                    # -------------------------------------------------
                    if recalcular_existentes:
                        print(f"🔁 recalcular_existentes=True -> construyendo NUEVA SR para {dia_key}", flush=True)

                        sr_pack_tmp = construir_sr_con_fallback_mixto(
                            window_end=cierre,
                            meses_preferidos=1,
                            meses_max=6,
                            min_quiet_days=3
                        )

                        nuevo_sr_run_id = guardar_sr_en_bd(
                            sr_pack_tmp,
                            run_time=pd.Timestamp(cierre).to_pydatetime(),
                            source="mixto",
                            notes=f"SR recalculada en backfill para día {dia_key}"
                        )

                        sr_pack_tmp["sr_run_id"] = nuevo_sr_run_id
                        sr_cache_por_dia[dia_key] = sr_pack_tmp

                        print(f"💾 Nueva SR guardada: run_id={nuevo_sr_run_id} para {dia_key}", flush=True)

                    # -------------------------------------------------
                    # Si NO se forzó recálculo, reusar si existe
                    # -------------------------------------------------
                    else:
                        sr_existente_id = buscar_sr_run_existente(cierre, source="mixto")

                        if sr_existente_id is not None:
                            print(f"♻️ Reusando SR existente run_id={sr_existente_id} para {dia_key}", flush=True)

                            sr = cargar_sr_desde_bd(sr_existente_id)
                            meta = leer_sr_run_meta(sr_existente_id)

                            sr_cache_por_dia[dia_key] = {
                                "sr": sr,
                                "quiet_days": [None] * int(meta["quiet_days_used"]) if meta["quiet_days_used"] is not None else [],
                                "sr_start": pd.Timestamp(meta["sr_start"]) if meta["sr_start"] is not None else None,
                                "sr_end": pd.Timestamp(meta["sr_end"]) if meta["sr_end"] is not None else None,
                                "meses_usados": int(meta["sr_months_used"]) if meta["sr_months_used"] is not None else None,
                                "sr_run_id": sr_existente_id
                            }

                        else:
                            print(f"🆕 No existía SR del día {dia_key}, construyendo nueva...", flush=True)

                            sr_pack_tmp = construir_sr_con_fallback_mixto(
                                window_end=cierre,
                                meses_preferidos=1,
                                meses_max=6,
                                min_quiet_days=3
                            )

                            nuevo_sr_run_id = guardar_sr_en_bd(
                                sr_pack_tmp,
                                run_time=pd.Timestamp(cierre).to_pydatetime(),
                                source="mixto",
                                notes=f"SR usada en backfill para día {dia_key}"
                            )

                            sr_pack_tmp["sr_run_id"] = nuevo_sr_run_id
                            sr_cache_por_dia[dia_key] = sr_pack_tmp

                            print(f"💾 Nueva SR guardada: run_id={nuevo_sr_run_id} para {dia_key}", flush=True)

                # =================================================
                # USAR SR YA PREPARADA EN CACHE PARA ESE DÍA
                # =================================================
                sr_pack = sr_cache_por_dia[dia_key]

                window_end = pd.Timestamp(cierre).floor("h")
                window_start = window_end - pd.Timedelta(hours=3) + pd.Timedelta(minutes=1)

                print(f"📥 Ventana 3h: {window_start} -> {window_end}", flush=True)

                df_win = leer_serie_k_minuto_mixta(
                    window_start,
                    window_end + pd.Timedelta(minutes=1)
                )

                if df_win.empty:
                    print(f"❌ Ventana vacía: {cierre}", flush=True)
                    errores.append({
                        "time_calc": str(cierre),
                        "error": "Ventana vacía"
                    })
                    continue

                sr = sr_pack["sr"]
                quiet_days = sr_pack["quiet_days"]
                sr_start = sr_pack["sr_start"]
                sr_end = sr_pack["sr_end"]
                meses_usados = sr_pack["meses_usados"]

                df_win = df_win.copy()
                df_win["minute_of_day"] = df_win.index.hour * 60 + df_win.index.minute
                df_win = df_win.join(sr, on="minute_of_day")
                df_win["RH"] = df_win["H"] - df_win["SR_H"]

                rh = df_win["RH"].dropna()

                if len(rh) < 120:
                    warming_up += 1
                    print(f"⚠️ Cobertura insuficiente en {cierre}: {len(rh)}/180", flush=True)
                    continue

                range_h = float(rh.max() - rh.min())
                k_est = rango_a_k_placeholder(range_h)

                payloads_ok.append({
                    "time_calc": window_end.to_pydatetime(),
                    "window_start": window_start.to_pydatetime(),
                    "window_end": window_end.to_pydatetime(),
                    "range_h": range_h,
                    "range_d": None,
                    "range_used": range_h,
                    "component_used": "H",
                    "k_est": int(k_est),
                    "qc_flag": 0,
                    "n_valid_h": int(len(rh)),
                    "n_valid_d": None,
                    "sr_start": sr_start.to_pydatetime() if sr_start is not None else None,
                    "sr_end": (sr_end - pd.Timedelta(minutes=1)).to_pydatetime() if sr_end is not None else None,
                    "quiet_days_used": int(len(quiet_days)) if quiet_days is not None else None,
                    "sr_run_id": sr_pack.get("sr_run_id"),
                    "sr_months_used": int(meses_usados) if meses_usados is not None else None
                })

                insertados += 1
                pendientes = len(payloads_ok)
                print(
                    f"✅ Listo {cierre} | K={k_est} | RH={len(rh)}/180 | "
                    f"insertados_memoria={insertados} | pendientes_sin_guardar={pendientes} | "
                    f"sr_run_id={sr_pack.get('sr_run_id')}",
                    flush=True
                )

                if len(payloads_ok) >= batch_size:
                    guardados_batch, payloads_ok = flush_krt_payloads(
                        payloads_ok,
                        procesados=procesados,
                        total_cierres=total_cierres,
                        insertados_memoria=insertados,
                        guardados_total=guardados_total,
                        omitidos_existentes=omitidos_existentes,
                        warming_up=warming_up,
                        errores=errores,
                        motivo=f"batch_size={batch_size}"
                    )
                    guardados_total += guardados_batch

            except Exception as e:
                print(f"❌ Error en {cierre}: {e}", flush=True)
                errores.append({
                    "time_calc": str(cierre),
                    "error": str(e)
                })

        guardados_final = 0
        if payloads_ok:
            guardados_final, payloads_ok = flush_krt_payloads(
                payloads_ok,
                procesados=procesados,
                total_cierres=total_cierres,
                insertados_memoria=insertados,
                guardados_total=guardados_total,
                omitidos_existentes=omitidos_existentes,
                warming_up=warming_up,
                errores=errores,
                motivo="final"
            )
            guardados_total += guardados_final

        print(
            f"🏁 BACKFILL terminado | procesados={procesados}/{total_cierres} | "
            f"insertados_memoria={insertados} | "
            f"guardados_total={guardados_total} | "
            f"pendientes_finales={len(payloads_ok)} | "
            f"omitidos_existentes={omitidos_existentes} | "
            f"warming_up={warming_up} | "
            f"errores={len(errores)}",
            flush=True
        )

        return {
            "ok": True,
            "fecha_inicio": str(inicio),
            "fecha_fin": str(fin),
            "cierres_trihorarios": True,
            "procesados": procesados,
            "insertados_memoria": insertados,
            "guardados_total": guardados_total,
            "pendientes_finales": len(payloads_ok),
            "batch_size": batch_size,
            "omitidos_existentes": omitidos_existentes,
            "warming_up_omitidos": warming_up,
            "guardados_ultimo_batch": guardados_final,
            "errores_n": len(errores),
            "errores": errores[:20]
        }

    except Exception as e:
        print(f"❌ Error en /krt/backfill_historico: {e}", flush=True)
        traceback.print_exc()
        return JSONResponse({"error": str(e)}, status_code=500)

