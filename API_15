def backfill_dst_desde_lemi(fecha_inicio, fecha_fin=None):
    if SQ_STATE.a0 is None or SQ_STATE.a1 is None:
        raise RuntimeError("No hay coeficientes Sq cargados.")
    conn = None
    try:
        conn = get_connection()
        cur  = conn.cursor()
        if fecha_fin is None:
            fecha_fin = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        cur.execute(f"""
            SELECT time, x FROM {TABLE_LEMI}
            WHERE time >= %s AND time <= %s AND x IS NOT NULL
            ORDER BY time ASC
        """, (fecha_inicio, fecha_fin))
        rows = cur.fetchall()
        if not rows:
            return {"ok": True, "msg": "Sin datos LEMI en ese rango.", "insertados": 0}
        buckets = {}
        for t, dx_raw in rows:
            minuto = t.replace(second=0, microsecond=0)
            H = H0 + float(dx_raw)
            m = t.hour * 60 + t.minute
            I_model = SQ_STATE.a0 + SQ_STATE.a1 * m
            buckets.setdefault(minuto, []).append(H - I_model)
        insertados = 0
        for minuto, vals in buckets.items():
            avg_E = sum(vals) / len(vals)
            cur.execute("""
                INSERT INTO DST (time, E_avg)
                VALUES (%s, %s)
                ON DUPLICATE KEY UPDATE E_avg = VALUES(E_avg)
            """, (minuto.strftime("%Y-%m-%d %H:%M:%S"), avg_E))
            insertados += 1
        conn.commit()
        return {"ok": True, "insertados": insertados}
    except Exception as e:
        raise RuntimeError(f"Error backfill: {e}")
    finally:
        if conn:
            conn.close()

