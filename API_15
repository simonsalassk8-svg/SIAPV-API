LAMBDA_B_RAD = np.radians(16.457)   # latitud geomagnética FUQ
WIDTH_FACTOR = 0.046831
MAX_D, MAX_M, MAX_A = 12, 1, 1
HIST_MINUTOS = 43200                 # 30 días de historial para FFT

