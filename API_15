def leer_serie_k_minuto(start, end, min_samples_per_minute=20):
    """
    Lee SOLO LEMI al segundo y lo remuestrea a minuto.
    En esta fase usa solo H, así que exige solo x no nulo.
    """
    conn = get_connection()
    try:
        q = f"""
            SELECT time, x
            FROM {TABLE_LEMI}
            WHERE time >= %s AND time < %s
              AND x IS NOT NULL
            ORDER BY time ASC
        """
        df = pd.read_sql(q, conn, params=[start, end])
    finally:
        conn.close()

    if df.empty:
        return pd.DataFrame(columns=["H"])

    df["time"] = pd.to_datetime(df["time"], errors="coerce")
    df = df.dropna(subset=["time"]).set_index("time").sort_index()
    df["x"] = pd.to_numeric(df["x"], errors="coerce")

    df["H"] = H0 + df["x"]
    base = df[["H"]].copy()

    counts = base.resample("1min").count()
    means  = base.resample("1min").mean()

    means.loc[counts["H"] < min_samples_per_minute, "H"] = np.nan

    return means


def seleccionar_quiet_days_simple(df, min_puntos_dia=1200, quiet_por_mes=5):
    """
    Selección inicial simple:
    escoge los días con menor delta diario de H.
    Más adelante la cambiamos por K preliminar < 3.
    """
    rows = []

    for fecha, g in df.dropna(subset=["H"]).resample("D"):
        if len(g) < min_puntos_dia:
            continue

        delta_h = g["H"].diff().abs().mean()

        rows.append({
            "fecha": pd.Timestamp(fecha),
            "delta_h": delta_h,
            "n": len(g)
        })

    daily = pd.DataFrame(rows)
    if daily.empty:
        return []

    daily["mes"] = daily["fecha"].dt.to_period("M")
    quiet = (
        daily.sort_values(["mes", "delta_h"])
             .groupby("mes")
             .head(quiet_por_mes)
    )

    return [pd.Timestamp(x).floor("D") for x in quiet["fecha"].tolist()]

def ajustar_sr_mejor_modelo(anchors, nivel_ref, max_grado_poly=8, max_grado_cheb=8,
                            usar_spline=True, usar_poly=True, usar_cheb=True,
                            penalizacion_rugosidad=0.001):
    """
    Prueba varios métodos de ajuste sobre las 24 anclas horarias y escoge
    el mejor según RMSE + penalización por rugosidad.

    Retorna:
      sr: DataFrame con SR_H por minuto
      resumen: DataFrame con métricas por modelo
      mejor_modelo: dict con info del ganador
    """
    import numpy as np
    import pandas as pd
    from scipy.interpolate import CubicSpline
    from numpy.polynomial.chebyshev import Chebyshev

    x_hour = np.arange(24) * 60 + 30
    y_hour = anchors.values.astype(float)

    x_min = np.arange(1440)

    resultados = []
    curvas = {}

    def metricas(nombre, y_fit_hour, y_fit_min):
        rmse = float(np.sqrt(np.mean((y_fit_hour - y_hour) ** 2)))

        # penalización por rugosidad basada en segunda derivada discreta
        d2 = np.diff(y_fit_min, n=2)
        rugosidad = float(np.mean(d2 ** 2)) if len(d2) > 0 else 0.0

        score = rmse + penalizacion_rugosidad * rugosidad

        resultados.append({
            "modelo": nombre,
            "rmse": rmse,
            "rugosidad": rugosidad,
            "score": score
        })

        curvas[nombre] = y_fit_min

    # ---------------------------------------------------
    # Spline periódico
    # ---------------------------------------------------
    if usar_spline:
        x_ext = np.r_[x_hour, 1440 + x_hour[0]]
        y_ext = np.r_[y_hour, y_hour[0]]

        cs = CubicSpline(x_ext, y_ext, bc_type="periodic")
        y_fit_min = cs(x_min)
        y_fit_hour = cs(x_hour)

        metricas("spline", y_fit_hour, y_fit_min)

    # ---------------------------------------------------
    # Polinomios
    # ---------------------------------------------------
    if usar_poly:
        for grado in range(3, max_grado_poly + 1):
            try:
                coeffs = np.polyfit(x_hour, y_hour, deg=grado)
                y_fit_min = np.polyval(coeffs, x_min)
                y_fit_hour = np.polyval(coeffs, x_hour)

                metricas(f"poly_{grado}", y_fit_hour, y_fit_min)
            except Exception:
                continue

    # ---------------------------------------------------
    # Chebyshev
    # ---------------------------------------------------
    if usar_cheb:
        for grado in range(3, max_grado_cheb + 1):
            try:
                cheb = Chebyshev.fit(x_hour, y_hour, deg=grado, domain=[0, 1439])
                y_fit_min = cheb(x_min)
                y_fit_hour = cheb(x_hour)

                metricas(f"cheb_{grado}", y_fit_hour, y_fit_min)
            except Exception:
                continue

    resumen = pd.DataFrame(resultados).sort_values("score").reset_index(drop=True)

    if resumen.empty:
        raise RuntimeError("No fue posible ajustar ningún modelo SR.")

    mejor_nombre = resumen.iloc[0]["modelo"]
    y_best_rel = curvas[mejor_nombre]
    sr_abs = nivel_ref + y_best_rel

    sr = pd.DataFrame(
        {"SR_H": sr_abs},
        index=pd.Index(range(1440), name="minute_of_day")
    )

    mejor_modelo = resumen.iloc[0].to_dict()

    return sr, resumen, mejor_modelo

def construir_anclas_horarias(df_hist, quiet_days, min_puntos_dia=1200):
    """
    A partir de quiet days ya seleccionados, construye:
      - 24 anclas horarias relativas
      - nivel de referencia absoluto
    """
    import numpy as np
    import pandas as pd

    hourly_rows = []
    daily_levels = []

    for d in quiet_days:
        ini = pd.Timestamp(d).floor("D")
        fin = ini + pd.Timedelta(days=1) - pd.Timedelta(minutes=1)

        dia = df_hist.loc[ini:fin].copy()
        if dia.empty:
            continue

        dia = dia.resample("1min").mean()

        if dia["H"].notna().sum() < min_puntos_dia:
            continue

        mediana_dia = dia["H"].median()
        if pd.isna(mediana_dia):
            continue

        daily_levels.append(float(mediana_dia))

        dia["H_rel"] = dia["H"] - mediana_dia
        dia["hour"] = dia.index.hour

        hh = dia.groupby("hour")["H_rel"].median()

        for hour, val in hh.items():
            if pd.notna(val):
                hourly_rows.append({
                    "hour": int(hour),
                    "H_rel_hour": float(val)
                })

    if not hourly_rows:
        raise RuntimeError("No hubo datos suficientes para construir anclas horarias.")

    if not daily_levels:
        raise RuntimeError("No fue posible calcular el nivel de referencia.")

    hourly_df = pd.DataFrame(hourly_rows)

    anchors = (
        hourly_df.groupby("hour")["H_rel_hour"]
        .median()
        .reindex(range(24))
        .interpolate(limit_direction="both")
    )

    if anchors.isna().any():
        raise RuntimeError("No fue posible completar las 24 anclas horarias.")

    nivel_ref = float(np.median(daily_levels))

    return anchors, nivel_ref

def construir_sr_canonica(df_hist, quiet_days, min_puntos_dia=1200):
    """
    Construye SR_H por minuto del día:
      - usando los quiet days actuales
      - construyendo anclas horarias
      - probando varios ajustes
      - escogiendo el mejor por RMSE + rugosidad
    """
    anchors, nivel_ref = construir_anclas_horarias(
        df_hist=df_hist,
        quiet_days=quiet_days,
        min_puntos_dia=min_puntos_dia
    )

    sr, resumen, mejor_modelo = ajustar_sr_mejor_modelo(
        anchors=anchors,
        nivel_ref=nivel_ref,
        max_grado_poly=8,
        max_grado_cheb=8,
        usar_spline=True,
        usar_poly=True,
        usar_cheb=True,
        penalizacion_rugosidad=0.001
    )

    print("\n=== SELECCIÓN AUTOMÁTICA DE AJUSTE SR ===")
    print(resumen.head(10).to_string(index=False))
    print(f"\nMejor modelo: {mejor_modelo['modelo']}")
    print(f"RMSE: {mejor_modelo['rmse']:.6f}")
    print(f"Rugosidad: {mejor_modelo['rugosidad']:.6f}")
    print(f"Score: {mejor_modelo['score']:.6f}")

    return {
        "sr": sr,
        "mejor_modelo": mejor_modelo,
        "resumen_modelos": resumen.to_dict(orient="records")
    }

def rango_a_k_placeholder(r):
    """
    Escala provisional para FUQ con K9 = 300 nT.
    limites = [0, 3, 6, 12, 24, 42, 72, 120, 198, 300]
    Escala provisional para FUQ con K9 = 350 nT.
    limites = [0, 3.5, 7, 14, 28, 49, 84, 140, 231, 350]
    """
    limites = [0, 3.5, 7, 14, 28, 49, 84, 140, 231, 350]
    for k in range(9):
        if r < limites[k + 1]:
            return k
    return 9

def construir_sr_con_fallback(window_end, meses_preferidos=1, meses_max=6, min_quiet_days=3):
    """
    Intenta construir la SR usando una ventana creciente hacia atrás:
    1 mes, 2 meses, 3 meses... hasta meses_max.
    """
    window_end = pd.Timestamp(window_end).floor("h")

    ultimo_error = None

    for meses in range(meses_preferidos, meses_max + 1):
        try:
            sr_start = (window_end - pd.DateOffset(months=meses)).floor("D")
            sr_end = window_end.floor("D") + pd.Timedelta(days=1)

            print(f">>> Intentando SR con {meses} mes(es): {sr_start} -> {sr_end}", flush=True)

            df_hist = leer_serie_k_minuto(sr_start, sr_end)
            print(f">>> df_hist.shape={df_hist.shape}", flush=True)

            if df_hist.empty:
                ultimo_error = f"Sin datos históricos para {meses} mes(es)"
                continue

            quiet_days = seleccionar_quiet_days_simple(df_hist)
            print(f">>> quiet_days encontrados={len(quiet_days)}", flush=True)

            if len(quiet_days) < min_quiet_days:
                ultimo_error = f"Muy pocos quiet days para {meses} mes(es): {len(quiet_days)}"
                continue

            sr_info = construir_sr_canonica(df_hist, quiet_days)

            return {
                "sr": sr_info["sr"],
                "quiet_days": quiet_days,
                "sr_start": sr_start,
                "sr_end": sr_end,
                "meses_usados": meses,
                "mejor_modelo": sr_info["mejor_modelo"],
                "resumen_modelos": sr_info["resumen_modelos"]
            }

        except Exception as e:
            ultimo_error = str(e)
            print(f"⚠️ Falló SR con {meses} mes(es): {e}", flush=True)

    raise RuntimeError(
        f"No fue posible construir SR con fallback hasta {meses_max} meses. Último error: {ultimo_error}"
    )


def calcular_k_para_hora_mixto(
    window_end,
    meses_sr=1,
    recalcular_existentes=False,
    usar_hampel_k=True,
    hampel_window=9,
    hampel_n_sigmas=6,
    hampel_replace_mode="median"
):
    """
    Calcula K para una hora de cierre usando:
      - SR guardada en BD si ya existe para el día
      - o la reconstruye si no existe / si recalcular_existentes=True
      - ventana de 3 horas desde fuente mixta

    El filtro Hampel, si está activado, afecta SOLO la serie usada para K
    en el tramo LEMI del flujo mixto.
    """
    print(f">>> Entró a calcular_k_para_hora_mixto | window_end={window_end}", flush=True)

    window_end = pd.Timestamp(window_end).floor("h")
    window_start = window_end - pd.Timedelta(hours=3) + pd.Timedelta(minutes=1)

    sr_run_id = buscar_sr_run_existente(window_end, source="mixto")

    # =========================================================
    # 1) Reusar SR existente SOLO si NO se forzó recálculo
    # =========================================================
    if sr_run_id is not None and not recalcular_existentes:
        print(f">>> Reusando SR existente: run_id={sr_run_id}", flush=True)

        sr = cargar_sr_desde_bd(sr_run_id)
        meta = leer_sr_run_meta(sr_run_id)

        sr_start = pd.Timestamp(meta["sr_start"]) if meta["sr_start"] is not None else None
        sr_end = pd.Timestamp(meta["sr_end"]) if meta["sr_end"] is not None else None
        quiet_days_used = int(meta["quiet_days_used"]) if meta["quiet_days_used"] is not None else None
        meses_usados = int(meta["sr_months_used"]) if meta["sr_months_used"] is not None else None

        # Si no guardas todavía el modelo de ajuste en BD, queda None
        sr_fit_model = meta.get("sr_fit_model", None) if isinstance(meta, dict) else None

    # =========================================================
    # 2) Construir SR nueva si:
    #    - no existe una previa, o
    #    - recalcular_existentes=True
    # =========================================================
    else:
        if sr_run_id is not None and recalcular_existentes:
            print(f">>> Forzando recálculo de SR aunque exista run_id={sr_run_id}", flush=True)
        else:
            print(">>> No existe SR del día, construyendo una nueva...", flush=True)

        sr_pack = construir_sr_con_fallback_mixto(
            window_end=window_end,
            meses_preferidos=meses_sr,
            meses_max=6,
            min_quiet_days=3
        )

        sr_run_id = guardar_sr_en_bd(
            sr_pack,
            run_time=window_end.to_pydatetime(),
            source="mixto",
            notes=f"SR usada para K en cierre {window_end}"
        )

        print(f">>> Nueva SR guardada con run_id={sr_run_id}", flush=True)

        sr = sr_pack["sr"]
        sr_start = sr_pack["sr_start"]
        sr_end = sr_pack["sr_end"]
        quiet_days_used = int(len(sr_pack["quiet_days"]))
        meses_usados = int(sr_pack["meses_usados"])
        sr_fit_model = sr_pack.get("mejor_modelo")

    # =========================================================
    # 3) Leer ventana de 3 horas
    # =========================================================
    df_win = leer_serie_k_minuto_mixta(
        window_start,
        window_end + pd.Timedelta(minutes=1),
        min_samples_per_minute=20,
        usar_hampel=usar_hampel_k,
        hampel_window=hampel_window,
        hampel_n_sigmas=hampel_n_sigmas,
        hampel_replace_mode=hampel_replace_mode
    )

    print(f">>> [MIXTO] df_win.shape: {df_win.shape}", flush=True)

    if df_win.empty:
        raise RuntimeError("No hay datos en la ventana de 3 horas.")

    # =========================================================
    # 4) Unir SR y calcular residual RH
    # =========================================================
    df_win = df_win.copy()
    df_win["minute_of_day"] = df_win.index.hour * 60 + df_win.index.minute
    df_win = df_win.join(sr, on="minute_of_day")

    if "SR_H" not in df_win.columns:
        raise RuntimeError("La SR cargada/construida no contiene la columna 'SR_H'.")

    df_win["RH"] = df_win["H"] - df_win["SR_H"]
    rh = df_win["RH"].dropna()

    print(f">>> [MIXTO] muestras válidas RH: {len(rh)}", flush=True)

    # =========================================================
    # 5) Validación cobertura
    # =========================================================
    if len(rh) < 120:
        return {
            "time_calc": window_end.to_pydatetime(),
            "window_start": window_start.to_pydatetime(),
            "window_end": window_end.to_pydatetime(),
            "range_h": None,
            "range_d": None,
            "range_used": None,
            "component_used": None,
            "k_est": None,
            "qc_flag": 1,
            "status": "warming_up",
            "message": f"Cobertura insuficiente para RH: {len(rh)}/180",
            "n_valid_h": int(len(rh)),
            "n_valid_d": None,
            "sr_start": sr_start.to_pydatetime() if sr_start is not None else None,
            "sr_end": (sr_end - pd.Timedelta(minutes=1)).to_pydatetime() if sr_end is not None else None,
            "quiet_days_used": quiet_days_used,
            "sr_months_used": meses_usados,
            "sr_run_id": sr_run_id,
            "sr_fit_model": sr_fit_model,
            "qc_method": "hampel_x_only" if usar_hampel_k else "none",
            "hampel_enabled": bool(usar_hampel_k),
            "hampel_window": int(hampel_window) if usar_hampel_k else None,
            "hampel_n_sigmas": float(hampel_n_sigmas) if usar_hampel_k else None,
            "hampel_replace_mode": str(hampel_replace_mode) if usar_hampel_k else None
        }

    # =========================================================
    # 6) Calcular rango y K
    # =========================================================
    range_h = float(rh.max() - rh.min())
    range_used = range_h
    component_used = "H"
    k_est = rango_a_k_placeholder(range_used)

    return {
        "time_calc": window_end.to_pydatetime(),
        "window_start": window_start.to_pydatetime(),
        "window_end": window_end.to_pydatetime(),
        "range_h": range_h,
        "range_d": None,
        "range_used": range_used,
        "component_used": component_used,
        "k_est": int(k_est),
        "qc_flag": 0,
        "status": "ok",
        "message": None,
        "n_valid_h": int(len(rh)),
        "n_valid_d": None,
        "sr_start": sr_start.to_pydatetime() if sr_start is not None else None,
        "sr_end": (sr_end - pd.Timedelta(minutes=1)).to_pydatetime() if sr_end is not None else None,
        "quiet_days_used": quiet_days_used,
        "sr_months_used": meses_usados,
        "sr_run_id": sr_run_id,
        "sr_fit_model": sr_fit_model,
        "qc_method": "hampel_x_only" if usar_hampel_k else "none",
        "hampel_enabled": bool(usar_hampel_k),
        "hampel_window": int(hampel_window) if usar_hampel_k else None,
        "hampel_n_sigmas": float(hampel_n_sigmas) if usar_hampel_k else None,
        "hampel_replace_mode": str(hampel_replace_mode) if usar_hampel_k else None
    }
    
