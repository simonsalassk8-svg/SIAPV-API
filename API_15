                gsm_index += 1

            H     = H0 + dH
            Z     = Z0 + dZ
            D_min = D0_min + dD_min
            D_rad = math.radians(D_min / 60.0)
            X     = H * math.cos(D_rad)
            Y     = H * math.sin(D_rad)

            if SQ_STATE.a0 is not None and SQ_STATE.a1 is not None:
                m = t.hour * 60 + t.minute
                I_model = SQ_STATE.a0 + SQ_STATE.a1 * m
